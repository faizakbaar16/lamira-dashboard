# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — NEVER expose in browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Google Sheets Sync (optional) ────────────────────────────────────────────
# 1. Create a Google Cloud project at console.cloud.google.com
# 2. Enable "Google Sheets API"
# 3. Create a Service Account, generate a JSON key
# 4. Share your Google Sheet with the service account email (Editor role)
# 5. Paste values below

GOOGLE_SERVICE_ACCOUNT_EMAIL=lamira-sync@your-project.iam.gserviceaccount.com

# Paste the entire private key — replace literal newlines with \n for Vercel
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
